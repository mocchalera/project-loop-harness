{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-loop-harness.dev/schemas/route-recommendation-v1.schema.json",
  "title": "Project Loop Harness Route Recommendation v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "policy_version",
    "target",
    "input_digest",
    "profile",
    "risk_level",
    "signals",
    "reason_codes",
    "work_brief_ref",
    "work_brief_sha256"
  ],
  "properties": {
    "contract_version": {"const": "route-recommendation/v1"},
    "policy_version": {"type": "string", "minLength": 1},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {"enum": ["goal", "task", "feature", "story", "defect", "workflow_run"]},
        "id": {"type": "string", "minLength": 1}
      }
    },
    "input_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "profile": {"enum": ["direct", "discover", "assure"]},
    "risk_level": {"enum": ["R0", "R1", "R2", "R3", "R4"]},
    "signals": {"type": "object"},
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[a-z0-9_.-]+$"}
    },
    "work_brief_ref": {"type": ["string", "null"], "pattern": "^evidence:E-[0-9]{4,}$"},
    "work_brief_sha256": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
