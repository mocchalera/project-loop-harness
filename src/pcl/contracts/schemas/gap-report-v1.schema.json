{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-loop-harness.dev/schemas/gap-report-v1.schema.json",
  "title": "Project Loop Harness Gap Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "producer",
    "generated_at",
    "target",
    "earliest_failed_handoff",
    "gap_class",
    "candidate_lessons"
  ],
  "properties": {
    "contract_version": {"const": "gap-report/v1"},
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    },
    "target": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "id"],
          "properties": {"type": {"const": "goal"}, "id": {"type": "string", "pattern": "^G-[0-9]{4,}$"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "id"],
          "properties": {"type": {"const": "task"}, "id": {"type": "string", "pattern": "^T-[0-9]{4,}$"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "id"],
          "properties": {"type": {"const": "feature"}, "id": {"type": "string", "pattern": "^F-[0-9]{4,}$"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "id"],
          "properties": {"type": {"const": "defect"}, "id": {"type": "string", "pattern": "^D-[0-9]{4,}$"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "id"],
          "properties": {"type": {"const": "workflow_run"}, "id": {"type": "string", "pattern": "^WR-[0-9]{4,}$"}}
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "id"],
          "properties": {"type": {"const": "agent_job"}, "id": {"type": "string", "pattern": "^J-[0-9]{4,}$"}}
        }
      ]
    },
    "related": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packet_id": {"type": "string", "pattern": "^cp-sha256:[0-9a-f]{64}$"},
        "evidence_refs": {"$ref": "#/$defs/evidenceRefs"},
        "workflow_run": {"type": "string", "pattern": "^WR-[0-9]{4,}$"}
      }
    },
    "earliest_failed_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "description"],
      "properties": {
        "stage": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1}
      }
    },
    "gap_class": {
      "enum": [
        "context",
        "capability",
        "domain_ownership",
        "authority",
        "proof",
        "feedback_delivery",
        "worker_limitation"
      ]
    },
    "candidate_lessons": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lesson_id", "lesson", "durable_owner", "evidence_refs"],
        "properties": {
          "lesson_id": {
            "type": "string",
            "pattern": "^lesson-[a-z0-9][a-z0-9._-]*$"
          },
          "lesson": {"type": "string", "minLength": 1},
          "durable_owner": {
            "enum": [
              "agents_md",
              "skill",
              "types",
              "api",
              "tests",
              "runbook",
              "project_docs",
              "tool_error_message"
            ]
          },
          "evidence_refs": {"$ref": "#/$defs/evidenceRefs"}
        }
      }
    }
  },
  "$defs": {
    "evidenceRefs": {
      "type": "array",
      "items": {"type": "string", "pattern": "^evidence:E-[0-9]{4,}$"}
    }
  }
}
