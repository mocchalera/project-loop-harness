{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-loop-harness.local/contracts/decision-proposal-v0.schema.json",
  "title": "Decision Proposal v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "proposal_id",
    "run_ref",
    "target",
    "question",
    "why_human_required",
    "impact_scope",
    "candidates",
    "recommended_candidate_id",
    "recommendation_reason",
    "unanswered_behavior",
    "unresolved_assumptions",
    "minority_opinions",
    "generated_by"
  ],
  "properties": {
    "contract_version": {
      "const": "decision-proposal/v0"
    },
    "proposal_id": {
      "type": "string",
      "pattern": "^DP-[0-9]{4,}$"
    },
    "run_ref": {
      "type": "string",
      "pattern": "^CR-"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "enum": [
            "goal",
            "task",
            "feature",
            "story",
            "defect",
            "workflow_run"
          ]
        },
        "id": {
          "type": "string",
          "pattern": "^[A-Z]{1,4}-[0-9]{4,}$"
        }
      }
    },
    "question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "why_human_required": {
      "type": "string",
      "minLength": 1,
      "maxLength": 3000
    },
    "impact_scope": {
      "type": "string",
      "minLength": 1,
      "maxLength": 3000
    },
    "candidates": {
      "type": "array",
      "minItems": 2,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "title",
          "summary",
          "benefits",
          "costs",
          "risks",
          "assumptions",
          "evidence_refs",
          "uncertainty",
          "reversibility",
          "reconsider_when"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "pattern": "^OPT-[A-Z0-9]{1,8}$"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3000
          },
          "benefits": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "costs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "assumptions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "uncertainty": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "reversibility": {
            "enum": [
              "easy",
              "moderate",
              "hard",
              "irreversible"
            ]
          },
          "reconsider_when": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    },
    "recommended_candidate_id": {
      "type": "string",
      "pattern": "^OPT-[A-Z0-9]{1,8}$"
    },
    "recommendation_reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 3000
    },
    "unanswered_behavior": {
      "const": "block"
    },
    "unresolved_assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "minority_opinions": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "participant_ids",
          "candidate_id",
          "argument",
          "evidence_refs"
        ],
        "properties": {
          "participant_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^P-[0-9]{2}$"
            },
            "uniqueItems": true
          },
          "candidate_id": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^OPT-[A-Z0-9]{1,8}$"
          },
          "argument": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3000
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    },
    "generated_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_ref",
        "participant_ids"
      ],
      "properties": {
        "run_ref": {
          "type": "string",
          "pattern": "^CR-"
        },
        "participant_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^P-[0-9]{2}$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
