{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-loop-harness.dev/schemas/completion-packet-v1.schema.json",
  "title": "Project Loop Harness completion-packet/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "packet_id",
    "producer",
    "generated_at",
    "outcome",
    "target",
    "repository",
    "changes",
    "checks",
    "claims",
    "unverified_claims",
    "risks",
    "human_decisions",
    "next_action"
  ],
  "properties": {
    "contract_version": {"const": "completion-packet/v1"},
    "packet_id": {"type": "string", "pattern": "^cp-sha256:[0-9a-f]{64}$"},
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": {"const": "project-loop-harness"},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    },
    "outcome": {
      "enum": [
        "COMPLETED_VERIFIED",
        "COMPLETED_WITH_RISK",
        "INCOMPLETE_VALIDATION",
        "INCOMPLETE_BUDGET_EXHAUSTED",
        "INCOMPLETE_HUMAN_DECISION_REQUIRED",
        "NO_CHANGES"
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "intent"],
      "properties": {
        "type": {"enum": ["goal", "task"]},
        "id": {"type": "string", "pattern": "^(G|T)-[0-9]{4,}$"},
        "intent": {"type": "string", "minLength": 1},
        "work_brief_ref": {
          "oneOf": [
            {"type": "string", "pattern": "^evidence:E-[0-9]{4,}$"},
            {"type": "null"}
          ]
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_revision", "head_revision", "diff_sha256", "dirty"],
      "properties": {
        "base_revision": {"type": "string", "minLength": 1},
        "head_revision": {"type": "string", "minLength": 1},
        "diff_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "dirty": {"type": "boolean"}
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "change_type"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "change_type": {"enum": ["added", "modified", "deleted", "renamed", "untracked"]},
          "previous_path": {"type": ["string", "null"], "minLength": 1}
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "command", "status", "exit_code", "artifact_ref", "reproducible", "reason"],
        "properties": {
          "id": {"type": "string", "pattern": "^CHK-[0-9]{4,}$"},
          "command": {"type": "string", "minLength": 1},
          "status": {"enum": ["passed", "failed", "skipped", "not_run", "timed_out"]},
          "exit_code": {"type": ["integer", "null"]},
          "artifact_ref": {
            "oneOf": [
              {"type": "string", "pattern": "^evidence:E-[0-9]{4,}$"},
              {"type": "null"}
            ]
          },
          "reproducible": {"type": "boolean"},
          "reason": {"type": ["string", "null"], "minLength": 1}
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "critical", "proof_level", "evidence_refs"],
        "properties": {
          "id": {"type": "string", "pattern": "^CL-[0-9]{4,}$"},
          "text": {"type": "string", "minLength": 1},
          "critical": {"type": "boolean"},
          "proof_level": {"enum": ["L0", "L1", "L2", "L3", "L4"]},
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string", "pattern": "^evidence:E-[0-9]{4,}$"}
          }
        }
      }
    },
    "unverified_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "reason", "critical"],
        "properties": {
          "text": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1},
          "critical": {"type": "boolean"}
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "text", "mitigation"],
        "properties": {
          "severity": {"enum": ["low", "medium", "high", "critical"]},
          "text": {"type": "string", "minLength": 1},
          "mitigation": {"type": ["string", "null"], "minLength": 1}
        }
      }
    },
    "human_decisions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "next_action": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["text", "command"],
          "properties": {
            "text": {"type": "string", "minLength": 1},
            "command": {"type": ["string", "null"], "minLength": 1}
          }
        },
        {"type": "null"}
      ]
    },
    "verifier_provenance": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "version", "evidence_ref"],
          "properties": {
            "kind": {"enum": ["human", "tool", "model"]},
            "name": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1},
            "evidence_ref": {
              "oneOf": [
                {"type": "string", "pattern": "^evidence:E-[0-9]{4,}$"},
                {"type": "null"}
              ]
            }
          }
        },
        {"type": "null"}
      ]
    }
  }
}
