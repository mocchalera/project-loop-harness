{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-loop-harness.dev/schemas/handoff-packet-v1.schema.json",
  "title": "Project Loop Harness handoff-packet/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version", "packet_id", "producer", "generated_at", "target",
    "current_state", "summary", "verified", "unverified", "decisions",
    "blockers", "risks", "next_safe_action", "context_refs",
    "token_estimator", "estimated_token_count", "size_bytes", "omitted_sections"
  ],
  "properties": {
    "contract_version": {"const": "handoff-packet/v1"},
    "packet_id": {"type": "string", "pattern": "^hp-sha256:[0-9a-f]{64}$"},
    "producer": {
      "type": "object", "additionalProperties": false, "required": ["name", "version"],
      "properties": {
        "name": {"const": "project-loop-harness"},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "generated_at": {"type": "string", "format": "date-time"},
    "target": {
      "type": "object", "additionalProperties": false, "required": ["type", "id"],
      "properties": {
        "type": {"enum": ["goal", "task"]},
        "id": {"type": "string", "pattern": "^(G|T)-[0-9]{4,}$"},
        "work_brief_ref": {"type": ["string", "null"]},
        "repository_revision": {"type": ["string", "null"]}
      }
    },
    "current_state": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "verified": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["text", "proof_level", "evidence_refs"],
        "properties": {
          "text": {"type": "string", "minLength": 1},
          "proof_level": {"enum": ["L1", "L2", "L3", "L4"]},
          "evidence_refs": {
            "type": "array", "minItems": 1,
            "items": {"type": "string", "pattern": "^evidence:E-[0-9]{4,}$"}
          }
        }
      }
    },
    "unverified": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false, "required": ["text", "reason"],
        "properties": {
          "text": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false, "required": ["id", "summary"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string", "pattern": "^evidence:E-[0-9]{4,}$"}
          }
        }
      }
    },
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "risks": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "next_safe_action": {
      "type": "object", "additionalProperties": false, "required": ["text", "command"],
      "properties": {
        "text": {"type": "string", "minLength": 1},
        "command": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "context_refs": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["ref", "kind", "freshness"],
        "properties": {
          "ref": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "minLength": 1},
          "freshness": {"enum": ["current", "stale", "unknown"]},
          "sha256": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"}
        }
      }
    },
    "restart_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_intent", "acceptance_status", "acceptance_ref",
        "target_review_command", "verification_commands",
        "evidence_resolution_commands", "changed_paths",
        "documentation_candidates"
      ],
      "properties": {
        "target_intent": {"type": "string", "minLength": 1},
        "acceptance_status": {"enum": ["intent_only", "work_brief_linked", "missing"]},
        "acceptance_ref": {
          "oneOf": [
            {"type": "string", "pattern": "^evidence:E-[0-9]{4,}$"},
            {"type": "null"}
          ]
        },
        "approval_provenance": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["event_id", "actor_kind", "actor", "source", "timestamp", "target", "bound_evidence"],
              "properties": {
                "event_id": {"type": "string", "minLength": 1},
                "actor_kind": {"enum": ["human", "agent", "system"]},
                "actor": {"type": "string", "minLength": 1},
                "recorder_kind": {"enum": ["human", "agent", "system"]},
                "recorder": {"type": "string", "minLength": 1},
                "source": {"type": "string", "minLength": 1},
                "source_kind": {"enum": ["cli", "conversation", "cockpit", "api"]},
                "source_ref": {"type": "string"},
                "timestamp": {"type": "string", "minLength": 1},
                "target": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type", "id"],
                  "properties": {
                    "type": {"type": "string", "minLength": 1},
                    "id": {"type": "string", "minLength": 1}
                  }
                },
                "bound_evidence": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "artifact_sha256"],
                  "properties": {
                    "id": {"type": "string", "pattern": "^E-[0-9]{4,}$"},
                    "artifact_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
                  }
                }
              }
            }
          ]
        },
        "target_review_command": {"type": "string", "minLength": 1},
        "verification_commands": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "previous_status", "evidence_refs", "proof_source"],
            "properties": {
              "command": {"type": "string", "minLength": 1},
              "previous_status": {"enum": ["passed", "failed", "skipped", "not_run", "timed_out"]},
              "evidence_refs": {
                "type": "array",
                "items": {"type": "string", "pattern": "^evidence:E-[0-9]{4,}$"}
              },
              "proof_source": {
                "type": "string",
                "pattern": "^completion-packet/v1\\.checks/CHK-[0-9]{4,}$"
              }
            }
          }
        },
        "evidence_resolution_commands": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^pcl evidence show E-[0-9]{4,} --json$"
          }
        },
        "changed_paths": {
          "type": "array", "maxItems": 50, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "documentation_candidates": {
          "type": "array", "maxItems": 50, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "intent_index_ref": {"type": ["string", "null"]},
    "budget_remaining": {"type": ["object", "null"]},
    "token_estimator": {"const": "charclass/v1"},
    "estimated_token_count": {"type": "integer", "minimum": 0},
    "size_bytes": {"type": "integer", "minimum": 0},
    "omitted_sections": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
