{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-loop-harness.dev/schemas/handoff-packet-v1.schema.json",
  "title": "PLH Handoff Packet v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "packet_id",
    "producer",
    "generated_at",
    "target",
    "current_state",
    "summary",
    "verified",
    "unverified",
    "decisions",
    "blockers",
    "risks",
    "next_safe_action",
    "context_refs"
  ],
  "properties": {
    "contract_version": {
      "const": "handoff-packet/v1"
    },
    "packet_id": {
      "type": "string"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "const": "project-loop-harness"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "work_brief_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "repository_revision": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "current_state": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "verified": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "text",
          "proof_level",
          "evidence_refs"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "proof_level": {
            "enum": [
              "L0",
              "L1",
              "L2",
              "L3",
              "L4"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "unverified": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "text",
          "reason"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_safe_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text",
        "command"
      ],
      "properties": {
        "text": {
          "type": "string"
        },
        "command": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "context_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ref",
          "kind",
          "freshness"
        ],
        "properties": {
          "ref": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "freshness": {
            "enum": [
              "current",
              "stale",
              "unknown"
            ]
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "intent_index_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "budget_remaining": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
