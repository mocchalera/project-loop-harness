{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-loop-harness.dev/schemas/knowledge-proposal-v0.schema.json",
  "title": "PLH Knowledge Proposal v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "id",
    "type",
    "scope",
    "claim",
    "provenance",
    "confidence",
    "status",
    "created_at"
  ],
  "properties": {
    "contract_version": {
      "const": "knowledge-proposal/v0"
    },
    "id": {
      "type": "string"
    },
    "type": {
      "enum": [
        "design_decision",
        "bug_pattern",
        "test_pattern",
        "project_constraint",
        "operational_note",
        "user_preference"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "ref"
      ],
      "properties": {
        "level": {
          "enum": [
            "task",
            "repository",
            "organization",
            "environment"
          ]
        },
        "ref": {
          "type": "string"
        }
      }
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_refs"
      ],
      "properties": {
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "work_brief_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "completion_packet_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "status": {
      "enum": [
        "proposed",
        "accepted",
        "rejected",
        "superseded",
        "expired",
        "needs_review"
      ]
    },
    "valid_from_revision": {
      "type": [
        "string",
        "null"
      ]
    },
    "valid_until_revision": {
      "type": [
        "string",
        "null"
      ]
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "supersedes": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewed_by": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
