{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-loop-harness.dev/schemas/work-brief-v1.schema.json",
  "title": "PLH Work Brief v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "id",
    "revision",
    "status",
    "target",
    "intent",
    "acceptance_criteria",
    "constraints",
    "non_goals",
    "assumptions",
    "route",
    "created_at"
  ],
  "properties": {
    "contract_version": {
      "const": "work-brief/v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "supersedes": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "draft",
        "approved",
        "superseded",
        "retired"
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "enum": [
            "project",
            "goal",
            "feature",
            "story",
            "task",
            "defect",
            "workflow_run"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "problem",
        "desired_outcome"
      ],
      "properties": {
        "problem": {
          "type": "string",
          "minLength": 1
        },
        "desired_outcome": {
          "type": "string",
          "minLength": 1
        },
        "target_user": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "text",
          "critical"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "critical": {
            "type": "boolean"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "text",
          "strength"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "strength": {
            "enum": [
              "invariant",
              "inherited_default",
              "local"
            ]
          },
          "source_evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        }
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "text",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "unverified",
              "supported",
              "contradicted",
              "retired"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        }
      }
    },
    "decision_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "route": {
      "$ref": "route-decision-v1.schema.json"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
