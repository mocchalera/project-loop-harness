{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-loop-harness.local/contracts/verification-plan-v0.schema.json",
  "title": "Verification Plan v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "verification_plan_id",
    "run_ref",
    "execution_policy",
    "items"
  ],
  "properties": {
    "contract_version": {
      "const": "verification-plan/v0"
    },
    "verification_plan_id": {
      "type": "string",
      "pattern": "^VPL-[0-9]{4,}$"
    },
    "run_ref": {
      "type": "string",
      "pattern": "^CR-"
    },
    "execution_policy": {
      "const": "proposal_only_never_auto_execute"
    },
    "items": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "verification_item_id",
          "claim_refs",
          "method",
          "description",
          "proposed_commands",
          "preconditions",
          "requires_human_approval",
          "safety_class",
          "expected_artifacts",
          "pass_condition",
          "failure_meaning",
          "estimated_effort",
          "status"
        ],
        "properties": {
          "verification_item_id": {
            "type": "string",
            "pattern": "^VP-[0-9]{3,}$"
          },
          "claim_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^C-[0-9]{3,}$"
            },
            "uniqueItems": true
          },
          "method": {
            "enum": [
              "repository_inspection",
              "deterministic_check",
              "official_source_review",
              "benchmark",
              "throwaway_prototype",
              "human_review"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3000
          },
          "proposed_commands": {
            "type": "array",
            "maxItems": 10,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 1000
            }
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "requires_human_approval": {
            "type": "boolean"
          },
          "safety_class": {
            "enum": [
              "read_only",
              "writes_worktree",
              "network",
              "dependency_change",
              "destructive"
            ]
          },
          "expected_artifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "pass_condition": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3000
          },
          "failure_meaning": {
            "type": "string",
            "minLength": 1,
            "maxLength": 3000
          },
          "estimated_effort": {
            "enum": [
              "small",
              "medium",
              "large",
              "unknown"
            ]
          },
          "status": {
            "const": "proposed"
          }
        }
      }
    }
  }
}
