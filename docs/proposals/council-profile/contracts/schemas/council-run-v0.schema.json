{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-loop-harness.local/contracts/council-run-v0.schema.json",
  "title": "Council Run v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "run_id",
    "request_ref",
    "orchestrator",
    "topology",
    "selection_rationale",
    "participants",
    "rounds",
    "budget",
    "privacy",
    "stop",
    "status",
    "started_at",
    "completed_at"
  ],
  "properties": {
    "contract_version": {
      "const": "council-run/v0"
    },
    "run_id": {
      "type": "string",
      "pattern": "^CR-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{8}$"
    },
    "request_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "request_digest"
      ],
      "properties": {
        "request_id": {
          "type": "string",
          "pattern": "^PRR-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{8}$"
        },
        "request_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "orchestrator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "policy_id",
        "policy_version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "policy_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "topology": {
      "enum": [
        "single",
        "parallel_synthesize",
        "propose_critique_revise",
        "specialist_pipeline"
      ]
    },
    "selection_rationale": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "participant_id",
          "role",
          "provider",
          "model_id_requested",
          "model_id_reported",
          "model_revision",
          "pinning_status",
          "settings",
          "context_isolation",
          "prompt_sha256"
        ],
        "properties": {
          "participant_id": {
            "type": "string",
            "pattern": "^P-[0-9]{2}$"
          },
          "role": {
            "enum": [
              "architect",
              "repository_analyst",
              "adversarial_reviewer",
              "security_reviewer",
              "verification_designer",
              "synthesizer",
              "generalist"
            ]
          },
          "provider": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "model_id_requested": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "model_id_reported": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 200
          },
          "model_revision": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 200
          },
          "pinning_status": {
            "enum": [
              "exact",
              "provider_alias",
              "unknown"
            ]
          },
          "settings": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "reasoning_effort",
              "temperature",
              "max_output_tokens"
            ],
            "properties": {
              "reasoning_effort": {
                "enum": [
                  "default",
                  "low",
                  "medium",
                  "high",
                  "max"
                ]
              },
              "temperature": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 0,
                "maximum": 2
              },
              "max_output_tokens": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 1
              }
            }
          },
          "context_isolation": {
            "enum": [
              "independent_first_pass",
              "shared",
              "shared_after_round_one"
            ]
          },
          "prompt_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "rounds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "round",
          "purpose",
          "participant_ids",
          "output_sha256"
        ],
        "properties": {
          "round": {
            "type": "integer",
            "minimum": 1
          },
          "purpose": {
            "enum": [
              "independent_proposal",
              "critique",
              "revision",
              "synthesis",
              "verification_design"
            ]
          },
          "participant_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^P-[0-9]{2}$"
            },
            "uniqueItems": true
          },
          "output_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "token_limit",
        "actual_input_tokens",
        "actual_output_tokens",
        "monetary_limit",
        "actual_cost",
        "currency",
        "cost_is_estimated"
      ],
      "properties": {
        "token_limit": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "actual_input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "actual_output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "monetary_limit": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "actual_cost": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "currency": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[A-Z]{3}$"
        },
        "cost_is_estimated": {
          "type": "boolean"
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "external_network_used",
        "providers_used",
        "repository_content_sent",
        "sensitive_content_sent",
        "secret_scan_performed"
      ],
      "properties": {
        "external_network_used": {
          "type": "boolean"
        },
        "providers_used": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "repository_content_sent": {
          "enum": [
            "none",
            "selected_snippets",
            "full"
          ]
        },
        "sensitive_content_sent": {
          "type": "boolean"
        },
        "secret_scan_performed": {
          "type": "boolean"
        }
      }
    },
    "stop": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason",
        "criteria_met",
        "unresolved_high_severity_claims",
        "new_high_severity_findings_last_round"
      ],
      "properties": {
        "reason": {
          "enum": [
            "criteria_satisfied",
            "no_new_high_severity_findings",
            "human_decision_required",
            "budget_exhausted",
            "wall_time_exhausted",
            "runner_error",
            "policy_skip"
          ]
        },
        "criteria_met": {
          "type": "boolean"
        },
        "unresolved_high_severity_claims": {
          "type": "integer",
          "minimum": 0
        },
        "new_high_severity_findings_last_round": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "status": {
      "enum": [
        "completed",
        "needs_human",
        "partial",
        "budget_exhausted",
        "failed",
        "skipped"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
